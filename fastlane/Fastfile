lane :buildAndDebug do
  gradle(
    task: "mobile:assembleGoogleDebug tv:assembleGoogleDebug",
    print_command: false
  )
end

# -------------------------------------------------
# PLAY STORE INTERNAL TRACK
# -------------------------------------------------
desc "Upload to Play Store Internal Testing Track (official release channel)"
lane :publishToPlayStoreInternal do
  buildAndSign(task: "mobile:bundleGoogleRelease tv:bundleGoogleRelease")

  supply(
    version_name: ENV['VERSION_NAME'],
    track: "internal",
    skip_upload_metadata: true,
    skip_upload_images: true,
    skip_upload_screenshots: true,
    aab_paths: Actions.lane_context[SharedValues::GRADLE_ALL_AAB_OUTPUT_PATHS],
    mapping_paths: [
      "mobile/build/outputs/mapping/googleRelease/mapping.txt",
      "tv/build/outputs/mapping/googleRelease/mapping.txt"
    ]
  )

  UI.success("✅ Published to Play Store Internal testing track")

  if ENV['SLACK_URL']
    mobile_version_code = File.read("../build.gradle.kts")
      .match(/extra\["appVersionCode"\] = (\d+)/)[1]

    changelog_file = "#{ENV['CHANGE_LOG_PATH']}#{mobile_version_code}.txt"
    changelog_content = File.exist?(changelog_file) ? File.read(changelog_file) : ""

    slack(
      message: "🚀 New version available on Play Store Internal Track",
      slack_url: ENV['SLACK_URL'],
      payload: {
        "Version" => ENV['VERSION_NAME'],
        "Track" => "Internal",
        "Changelog" => changelog_content.empty? ? "No changelog provided" : changelog_content
      },
      default_payloads: [:git_branch, :git_author],
      success: true
    )
  end
end

# -------------------------------------------------
# INTERNAL APP SHARING
# -------------------------------------------------
desc "Upload to Internal App Sharing (quick test URLs for QA)"
lane :publishToInternalAppSharing do
  buildAndSign(task: "mobile:bundleGoogleRelease tv:bundleGoogleRelease")

  mobile_share_url = upload_to_play_store_internal_app_sharing(
    package_name: ENV['PACKAGE_NAME'],
    aab: "mobile/build/outputs/bundle/googleRelease/mobile-google-release.aab"
  )

  UI.success("📱 Mobile uploaded: #{mobile_share_url}")

  sleep(2)

  tv_share_url = upload_to_play_store_internal_app_sharing(
    package_name: ENV['PACKAGE_NAME'],
    aab: "tv/build/outputs/bundle/googleRelease/tv-google-release.aab"
  )

  UI.success("📺 TV uploaded: #{tv_share_url}")

  UI.success("📦 Internal App Sharing URLs")
  UI.success("📱 Mobile: #{mobile_share_url}")
  UI.success("📺 TV: #{tv_share_url}")

  if ENV['SLACK_URL']
    commit_messages = changelog_from_git_commits(
      commits_count: 5,
      pretty: "• %s",
      merge_commit_filtering: "exclude_merges"
    )

    payload_data = {
      "Version" => ENV['VERSION_NAME'],
      "📱 Mobile URL" => mobile_share_url,
      "📺 TV URL" => tv_share_url,
      "Recent Commits" => commit_messages
    }

    if ENV['CI_MERGE_REQUEST_IID']
      mr_url = "#{ENV['CI_PROJECT_URL']}/-/merge_requests/#{ENV['CI_MERGE_REQUEST_IID']}"
      payload_data["Merge Request"] =
        "<#{mr_url}|!#{ENV['CI_MERGE_REQUEST_IID']} - #{ENV['CI_MERGE_REQUEST_TITLE']}>"
    end

    if ENV['CI_PIPELINE_URL']
      payload_data["Pipeline"] =
        "<#{ENV['CI_PIPELINE_URL']}|##{ENV['CI_PIPELINE_IID']}>"
    end

    slack(
      message: "📦 New build available for testing (Internal App Sharing)",
      slack_url: ENV['SLACK_URL'],
      payload: payload_data,
      default_payloads: [:git_branch, :git_author],
      success: true
    )
  end
end

