default_platform(:android)

desc "Runs tests"
lane :test do
  gradle(task: "test")
end

desc "Pull Build number from play store, increment and update gradle."
lane :updateBuildVersion do
  code = google_play_track_version_codes(
    package_name: ENV['PACKAGE_NAME'],
    track: "internal"
  )

  if code.length >= 2
    mobile_version = code[1] + 1
    tv_version = mobile_version + 1
  else
    mobile_version = (code[0] || 0) + 1
    tv_version = mobile_version + 1
  end

  gradle_file = File.read("../build.gradle.kts")
  gradle_file.gsub!(
    /extra\["appVersionCode"\] = \d+/,
    "extra[\"appVersionCode\"] = #{mobile_version}"
  )
  File.write("../build.gradle.kts", gradle_file)

  UI.success("✅ Updated appVersionCode to #{mobile_version} (TV will be #{tv_version})")
end

desc "Pull Build number from play store and keep same."
lane :keepBuildVersion do
  code = google_play_track_version_codes(
    package_name: ENV['PACKAGE_NAME'],
    track: "internal"
  )

  if code.length >= 2
    mobile_version = code[0]
    tv_version = code[1]
  else
    mobile_version = code[0] || 0
    tv_version = mobile_version + 1
  end

  gradle_file = File.read("../build.gradle.kts")
  gradle_file.gsub!(
    /extra\["appVersionCode"\] = \d+/,
    "extra[\"appVersionCode\"] = #{mobile_version}"
  )
  File.write("../build.gradle.kts", gradle_file)

  UI.success("✅ Kept appVersionCode at #{mobile_version} (TV will be #{tv_version})")
end

